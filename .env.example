# EEA Swarm Mission Planner - Environment Configuration
# Copy this file to .env and adjust values as needed.

# Application
APP_NAME=EEA Swarm Mission Planner
APP_ENV=development
LOG_LEVEL=INFO

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# Default Mission Parameters (overridable via UI)
DEFAULT_FIELD_SIZE_HA=50
DEFAULT_DRONE_COUNT=4
DEFAULT_BATTERY_CAPACITY_MAH=5000
DEFAULT_LIQUID_CAPACITY_L=10
