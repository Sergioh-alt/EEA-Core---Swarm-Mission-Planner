# ORIÓN Mission Control UI — environment configuration
#
# Digital Twin API base URL. When set, the UI runs in LIVE mode and consumes
# real REST + WebSocket data from the Digital Twin API server (backend/).
# When unset, the UI runs in development mock mode (self-contained demo data).
#
#   Start the API server:  python -m backend.run
#
NEXT_PUBLIC_TWIN_API_URL=http://localhost:8000

# Optional: Mapbox access token. Without it, the map falls back to OSM tiles.
# NEXT_PUBLIC_MAPBOX_TOKEN=
